# MeetScribe configuration
# Copy to .env and adjust paths as needed

# Data directory (DB, logs, sessions, voiceprints, samples)
MEETSCRIBE_DATA_DIR=./data

# Temp directory (default: DATA_DIR/tmp)
# MEETSCRIBE_TMP_DIR=./data/tmp

# Max upload size in bytes (default: 4GB)
# MEETSCRIBE_MAX_UPLOAD_SIZE=4294967296
